# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=glashaus-blocks
S3_DATASTORE_BUCKET=glashaus-data
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Node Configuration
NODE_INTERNAL_PORT=4000
API_HOST=127.0.0.1          # HTTP API binding: 127.0.0.1 (localhost only) or 0.0.0.0 (all interfaces, only if behind reverse proxy with auth)
ANNOUNCE_IP=127.0.0.1

# Network Configuration
LIBP2P_PORT=4001
LIBP2P_WS_PORT=4002

# Optional: Bootstrap peers (comma-separated multiaddrs)
# BOOTSTRAP_PEERS=/ip4/1.2.3.4/tcp/4001/p2p/12D3Koo...,/ip4/5.6.7.8/tcp/4001/p2p/12D3Koo...

# Logging
LOG_LEVEL=info

# Performance Tuning
BLOCK_CACHE_MB=512
BITSWAP_WANT_TIMEOUT_MS=5000
DHT_PROVIDER_TIMEOUT_MS=5000

# Environment
NODE_ENV=development

{
  "name": "ipfs-shard",
  "version": "0.7.4",
  "type": "module",
  "description": "Production-ready, server-native IPFS node with S3 storage option and strong peer connectivity",
  "author": "Glashaus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ipfs-shard.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ipfs-shard/issues"
  },
  "homepage": "https://github.com/yourusername/ipfs-shard#readme",
  "keywords": [
    "ipfs",
    "p2p",
    "distributed-storage",
    "dht",
    "s3",
    "libp2p",
    "bitswap",
    "content-routing"
  ],
  "scripts": {
    "dev": "nodemon",
    "start": "tsx dist/index.js",
    "build": "tsc && echo 'Build complete: ./dist'",
    "test": "node --import tsx/esm --test 'test/{health,peers,blocks,ping,providers,metrics,announce,connect,network,dagstat,dht-promote}.spec.js'",
    "test:watch": "node --import tsx/esm --test --watch 'test/{health,peers,blocks,ping,providers,metrics,announce,connect,network,dagstat,dht-promote}.spec.js'",
    "test:integration": "node --import tsx/esm --test --test-global-setup=test/helpers/server.js 'test/**/*.spec.js'",
    "test:health": "node --import tsx/esm --test test/health.spec.js",
    "test:peers": "node --import tsx/esm --test test/peers.spec.js",
    "test:ping": "node --import tsx/esm --test test/ping.spec.js",
    "test:providers": "node --import tsx/esm --test test/providers.spec.js",
    "test:blocks": "node --import tsx/esm --test test/blocks.spec.js",
    "test:network": "node --import tsx/esm --test test/network.spec.js",
    "test:announce": "node --import tsx/esm --test test/announce.spec.js",
    "test:connect": "node --import tsx/esm --test test/connect.spec.js",
    "test:metrics": "node --import tsx/esm --test test/metrics.spec.js",
    "test:dagstat": "node --import tsx/esm --test test/dagstat.spec.js",
    "test:dht-promote": "node --import tsx/esm --test test/dht-promote.spec.js",
    "test:dht-promote:long": "node --import tsx/esm --test test/dht-promote-long.spec.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.11",
    "@libp2p/identify": "^4.0.6",
    "@libp2p/kad-dht": "^16.1.3",
    "@libp2p/mdns": "^12.0.11",
    "@libp2p/ping": "^3.0.12",
    "@libp2p/prometheus-metrics": "^5.0.11",
    "@libp2p/tcp": "^11.0.10",
    "@libp2p/websockets": "^10.1.3",
    "@multiformats/multiaddr": "^12.5.1",
    "blockstore-s3": "^3.0.1",
    "datastore-s3": "^13.0.1",
    "dotenv": "^17.2.3",
    "libp2p": "^3.1.5",
    "lru-cache": "^11.2.6",
    "multiformats": "^13.4.2",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "nodemon": "^3.1.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
